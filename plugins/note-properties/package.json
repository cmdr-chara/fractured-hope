{
  "name": "@quartz-community/note-properties",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "main": "./index.ts",
  "scripts": {
    "build": "node -e \"process.exit(0)\""
  },
  "quartz": {
    "name": "note-properties",
    "displayName": "Note Properties",
